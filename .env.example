# ─────────────────────────────────────────────────────────────────────────────
# XYZMed configuration. Copy to .env for local dev.
# Loaded by koanf: defaults -> .env -> process env (env wins). Keys are UPPER_SNAKE.
# In prod (APP_ENV=prod) these come from ECS task env / SSM / Secrets Manager.
# ─────────────────────────────────────────────────────────────────────────────

# dev | prod  - selects mailer/SMS providers and logging format.
APP_ENV=dev

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
# Comma-separated allowed origins for CORS (frontend dev server).
HTTP_CORS_ORIGINS=http://localhost:3000

# Postgres (RDS in prod). Used by both API and worker.
DB_DSN=postgres://xyzmed:xyzmed@postgres:5432/xyzmed?sslmode=disable

# Redis / Valkey (ElastiCache in prod). Refresh tokens, OTP, asynq queue.
REDIS_ADDR=valkey:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=dev-only-change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=xyzmed

# Google OAuth (ID-token verification)
GOOGLE_OAUTH_CLIENT_ID=

# Email - dev: Mailhog SMTP; prod: SES
MAIL_FROM=no-reply@xyzmed.local
MAIL_SMTP_HOST=mailhog
MAIL_SMTP_PORT=1025
# prod (APP_ENV=prod) uses SES in this region instead of SMTP
AWS_REGION=ap-south-1

# Base URL included in password-reset links (no trailing slash)
MAIL_APP_URL=http://localhost:3000

# SMS / OTP - dev logs the OTP; prod uses a provider (MSG91/Twilio adapter)
SMS_PROVIDER=log
OTP_TTL=5m
OTP_MAX_ATTEMPTS=5

# OpenTelemetry -> grafana-otel-lgtm (OTLP gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4317
OTEL_SERVICE_NAME=xyzmed-api

# Pyroscope continuous profiling (bundled inside grafana/otel-lgtm on port 4040)
PYROSCOPE_URL=http://lgtm:4040

# First-boot super admin. If SUPER_ADMIN_EMAIL is set and no super_admin exists,
# the API creates one on startup (idempotent). Leave blank after first boot or use
# Secrets Manager in prod.
SUPER_ADMIN_EMAIL=admin@xyzmed.local
SUPER_ADMIN_PASSWORD=change-me-on-first-login
